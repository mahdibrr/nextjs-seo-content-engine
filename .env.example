# nextjs-seo-content-engine — environment variables
# Copy to .env and fill in your values.

# Your site
SITE_URL=https://your-blog.com
SITE_DOMAIN=your-blog.com
SITE_NAME=Your Blog
SITE_NICHE=Next.js, Supabase, and full-stack web development
AUTHOR_NAME=Your Name

# Slugs to exclude from scoring/optimization (comma-separated)
# OFF_TOPIC_SLUGS=slug-one,slug-two

# AI provider (required for content generation)
# Ollama (local, free):
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=deepseek-r1:671b
# AI_API_KEY=   # not needed for Ollama

# OpenAI:
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=sk-...

# DeepSeek:
# AI_PROVIDER=deepseek
# AI_MODEL=deepseek-chat
# AI_API_KEY=...

# Groq (fast inference, free tier):
# AI_PROVIDER=custom
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
# AI_API_KEY=gsk_...

# Optional fallback account on 429:
# AI_API_KEY_2=...

# Google Search Console (service account):
# GSC_SITE_URL=https://www.your-blog.com/
# GSC_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GSC_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Google Search Console (OAuth):
# GSC_SITE_URL=https://www.your-blog.com/
# GSC_CLIENT_ID=...
# GSC_CLIENT_SECRET=...
# GSC_REFRESH_TOKEN=...

# Optional integrations
# NOTIFICATION_MODULE=./src/lib/notifications/my-notifier.js
# ENABLE_NOTIFICATIONS=true
# EDITORIAL_SCORE_MODULE=./src/lib/scoring/my-editorial-score.js

# Content directories (defaults shown)
# DRAFTS_DIR=content/drafts
# REVIEW_DIR=content/review-pending
